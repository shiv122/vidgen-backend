# --- Django ---
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database (MySQL) ---
DB_NAME=vidgen
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- ElevenLabs (voice cloning + TTS) ---
ELEVENLABS_API_KEY=
ELEVEN_MODEL_ID=eleven_multilingual_v2
ELEVEN_OUTPUT_FORMAT=mp3_44100_128

# --- D-ID (talking-head video) ---
DID_API_KEY=

# --- Pipeline ---
DEFAULT_RESOLUTION=480
MAX_TEXT_LEN=2500
# Max upload size for the avatar image and voice sample (MB).
MAX_UPLOAD_MB=25
# Max upload size for the background video (MB).
MAX_VIDEO_MB=500
# D-ID rejects images over ~3.3 MP (decoded). Uploaded images are downscaled to
# this megapixel budget before being sent. Output is only 360-720p.
DID_MAX_IMAGE_MP=3.0
VIDEO_POLL_TIMEOUT=600
VIDEO_POLL_INTERVAL=5

# --- DigitalOcean Spaces (S3-compatible storage) ---
DO_ACCESS_KEY_ID=
DO_SECRET_ACCESS_KEY=
DO_BUCKET=
DO_DEFAULT_REGION=
DO_ENDPOINT=https://<region>.digitaloceanspaces.com
