{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": ["python manage.py collectstatic --noinput"]
    }
  },
  "deploy": {
    "aptPackages": ["ffmpeg"],
    "startCommand": "python manage.py migrate --noinput && gunicorn config.wsgi:application --bind 0.0.0.0:${PORT:-8000} --workers 3 --timeout 660",
    "variables": {
      "PYTHONUNBUFFERED": "1",
      "PYTHONDONTWRITEBYTECODE": "1"
    }
  }
}
